{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/miaowing-tab/wallpapers.schema.json",
  "title": "Miaowing Tab Wallpapers",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "categories"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "wallpapers"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "label": {
            "type": "object",
            "additionalProperties": false,
            "required": ["zh-CN", "en"],
            "properties": {
              "zh-CN": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "wallpapers": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/wallpaper"
            }
          }
        }
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "wallpaper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "thumb", "url", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "thumb": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["image", "video"]
        },
        "color": {
          "type": "string",
          "pattern": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "source": {
          "type": "string"
        }
      }
    }
  }
}
